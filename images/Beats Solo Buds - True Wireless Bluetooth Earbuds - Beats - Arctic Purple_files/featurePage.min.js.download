jQuery.namespace = function () {
    var win = null, index1, index2, item;
    for (index1 = 0; index1 < arguments.length; index1 = index1 + 1) {
        item = arguments[index1].split(".");
        win = window;
        for (index2 = 0; index2 < item.length; index2 = index2 + 1) {
            win[item[index2]] = win[item[index2]] || {};
            win = win[item[index2]];
        }
    }
    return win;
};

$.namespace("Beats.dashboard");

Beats.dashboard = function() {

    var self = this;
    this.components = {};

    this.init = function() {
//        getSearchParams();
        initDomEvents();
    };

    function detectImagesForAlt(e) {
        var target = e.target;

        if (target.tagName === 'IMG') {
            addAltAttribute(target);
        }
    }

    function addAltAttribute(img) {
        if (!img.hasAttribute('alt')) {
            img.alt = '';
        }
    }

    function initArticleContent(e) {

        var el = e.params.el[0];
        window.registerCarousel(el);
        window.initBeatsVideo(el);
        window.initImgTxt(el);
        window.initUniversalHero(el);
    }

    function initDomEvents() {
        /*
         * Added for A11y. HTL strips of alt tag when empty
         * Event capturing used since load event cannot be captured using bubbling
         */
        document.addEventListener('load', detectImagesForAlt, true);
        document.addEventListener('error', detectImagesForAlt, true);

        /* Fix to support Product Tile and Universal Hero in article details page  
         * PDP pages use its own instance of jquery. So events triggered from base js will not be captured.
         */
        $(document).on('articleContentLoaded', initArticleContent);
    }
};
$(document).ready(function(){
    var dashboard = new Beats.dashboard();
    dashboard.init();
});
